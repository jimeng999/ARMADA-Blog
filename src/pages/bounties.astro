---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';

const bountyTitle = "Enemies Drown Deep In Exile";
const bountyAbbrev = "E.D.D.I.E.";
const rewardAmount = "$100,000,000";
const pirateName = "Isaac Lombard";
const alias = "\"The Shadow Corsair\"";
const crimes = [
  "Piracy of digital goods",
  "Unauthorized fork of open-source projects",
  "Distribution of malicious npm packages",
  "Bounty fraud and scam operations",
  "Stealing CI/CD credentials via social engineering"
];
const lastSeen = "Somewhere in the npm registry";
const danger_level = "EXTREME";
---

<Base title={`${pirateName} - Wanted Dead or Alive`} description="Bounty poster for Isaac Lombard">
  <div class="min-h-screen bg-gradient-to-b from-red-950 via-red-900 to-amber-950 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-5xl md:text-7xl font-black text-amber-400 tracking-wider uppercase mb-2"
            style="font-family: Georgia, serif; text-shadow: 3px 3px 6px rgba(0,0,0,0.8);">
          WANTED
        </h1>
        <p class="text-xl text-amber-200 italic">
          {bountyTitle} — {bountyAbbrev}
        </p>
      </div>

      <!-- Bounty Poster -->
      <div class="bg-amber-100 border-8 border-amber-900 rounded-lg shadow-2xl overflow-hidden">
        <!-- Reward Banner -->
        <div class="bg-red-800 text-center py-4">
          <p class="text-3xl md:text-4xl font-black text-white uppercase tracking-widest"
             style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">
            REWARD
          </p>
          <p class="text-5xl md:text-6xl font-black text-yellow-300 uppercase tracking-wider"
             style="text-shadow: 3px 3px 6px rgba(0,0,0,0.7);">
            {rewardAmount}
          </p>
        </div>

        <!-- Portrait Section -->
        <div class="p-8 text-center">
          <!-- Pirate silhouette using CSS art -->
          <div class="relative w-48 h-48 mx-auto mb-6">
            <svg viewBox="0 0 200 200" class="w-full h-full grayscale" xmlns="http://www.w3.org/2000/svg">
              <!-- Hat -->
              <ellipse cx="100" cy="55" rx="70" ry="20" fill="#1a1a1a"/>
              <rect x="60" y="25" width="80" height="35" rx="5" fill="#1a1a1a"/>
              <!-- Skull on hat -->
              <circle cx="100" cy="45" r="12" fill="#f5f5dc"/>
              <circle cx="96" cy="43" r="3" fill="#1a1a1a"/>
              <circle cx="104" cy="43" r="3" fill="#1a1a1a"/>
              <rect x="96" y="48" width="8" height="4" rx="1" fill="#1a1a1a"/>
              <!-- Crossbones -->
              <line x1="70" y1="60" x2="130" y2="60" stroke="#1a1a1a" stroke-width="3"/>
              <line x1="75" y1="55" x2="125" y2="65" stroke="#1a1a1a" stroke-width="3"/>
              <line x1="75" y1="65" x2="125" y2="55" stroke="#1a1a1a" stroke-width="3"/>
              <!-- Head -->
              <circle cx="100" cy="95" r="35" fill="#d4a574"/>
              <!-- Eye patch -->
              <circle cx="85" cy="90" r="8" fill="#1a1a1a"/>
              <line x1="70" y1="82" x2="130" y2="75" stroke="#1a1a1a" stroke-width="2"/>
              <!-- Scar -->
              <line x1="110" y1="85" x2="125" y2="105" stroke="#8b4513" stroke-width="2"/>
              <!-- Mouth -->
              <path d="M 88 108 Q 100 115 112 108" stroke="#1a1a1a" stroke-width="2" fill="none"/>
              <!-- Bandana -->
              <path d="M 65 75 Q 100 65 135 75" stroke="#8b0000" stroke-width="4" fill="none"/>
              <!-- Body -->
              <path d="M 70 130 L 60 180 L 140 180 L 130 130 Z" fill="#2d1b0e"/>
              <!-- Coat tails -->
              <path d="M 60 180 L 55 200 L 80 190 Z" fill="#2d1b0e"/>
              <path d="M 140 180 L 145 200 L 120 190 Z" fill="#2d1b0e"/>
              <!-- Belt -->
              <rect x="65" y="155" width="70" height="8" rx="2" fill="#1a1a1a"/>
              <rect x="93" y="152" width="14" height="14" rx="2" fill="#d4af37"/>
            </svg>
          </div>

          <h2 class="text-4xl font-black text-gray-900 uppercase tracking-wider mb-1"
              style="font-family: Georgia, serif;">
            {pirateName}
          </h2>
          <p class="text-xl text-gray-600 italic mb-4">{alias}</p>

          <!-- Danger Level -->
          <div class="inline-block bg-red-700 text-white px-4 py-1 rounded-full text-sm font-bold uppercase tracking-wider mb-4">
            ⚠ Danger Level: {danger_level} ⚠
          </div>

          <!-- Crimes -->
          <div class="text-left bg-gray-50 rounded-lg p-4 mb-4">
            <h3 class="text-lg font-bold text-gray-800 mb-2 uppercase tracking-wide">Known Crimes:</h3>
            <ul class="space-y-1">
              {crimes.map((crime, i) => (
                <li class="flex items-start gap-2 text-gray-700">
                  <span class="text-red-600 font-bold mt-1">✦</span>
                  <span>{crime}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Last Seen -->
          <p class="text-gray-600">
            <strong>Last Seen:</strong> {lastSeen}
          </p>

          <!-- Warning -->
          <div class="mt-6 p-4 bg-red-100 border-2 border-red-600 rounded-lg">
            <p class="text-red-800 font-bold text-center uppercase tracking-wider">
              ⚠ Do Not Approach Alone ⚠
            </p>
            <p class="text-red-700 text-center text-sm mt-1">
              Armed and extremely dangerous. Report sightings immediately.
            </p>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="text-center mt-8">
        <p class="text-amber-200 text-sm">
          Issued by the {bountyAbbrev} • All hands authorized to capture
        </p>
      </div>
    </div>
  </div>
</Base>
