---
import Base from '../layouts/Base.astro';
import { getConfig } from '../lib/data';
import GoldChart from '../components/gold/GoldChart.astro';
import GrogChart from '../components/gold/GrogChart.astro';

const config = (await getConfig()).data?.config ?? null;
---

<Base
	title={`Gold Price · ${config?.seo?.title ?? 'TinaCMS + Astro'}`}
	description="Live gold price in Australian dollars with an interactive historical chart — a ship's-chart for the brass standard. Frontend-only, no accounts."
>
	<main class="mx-auto max-w-4xl px-6 py-12">
		<header class="mb-8 flex flex-col gap-3">
			<h1 class="text-4xl font-semibold tracking-tight">Gold Price</h1>
			<p class="max-w-2xl text-muted-foreground">
				A ship's-chart for the brass standard. The latest spot price of gold in
				Australian dollars, plus an interactive history you can range across —
				all plotted right here in your browser, no accounts and no downloads.
			</p>
			<hr class="rope-divider max-w-2xl" aria-hidden="true" />
		</header>

		<GoldChart />

		<section class="mt-12 flex flex-col gap-3">
			<h2 class="text-2xl font-semibold tracking-tight">For the grog ledger (just for fun)</h2>
			<p class="max-w-2xl text-muted-foreground">
				And now, something completely made up. Below is a wholly fictional
				"Doubloons→Grog" exchange rate — invented in your browser purely for a
				laugh. It is not real, it is not data, and it is certainly not advice.
			</p>
			<GrogChart />
		</section>
	</main>
</Base>
