---
import GameShell from './GameShell.astro';
import Leaderboard from './Leaderboard.astro';
---

<GameShell
	id="memory"
	title="Memory Match"
	instructions="Click/tap two cards to flip them. Find all matching pairs in as few moves as possible."
>
	<div id="mem-board" class="grid grid-cols-4 gap-2 touch-none select-none" style="width:16rem"></div>
	<p class="text-sm font-medium">Moves: <span id="mem-moves">0</span> · Pairs: <span id="mem-pairs">0</span>/8 · <span id="mem-status">Find the pairs</span></p>
	<button id="mem-reset" class="rounded-md border bg-background px-4 py-2 text-sm font-medium hover:bg-accent">New game</button>
	<Leaderboard game="memory" lowerIsBetter unit="moves" label="Move count" />
</GameShell>

<script is:inline>
	(() => {
		const board = document.getElementById('mem-board');
		if (!board) return;
		const ICONS = ['🚀', '🪐', '⭐', '🌙', '☄️', '🛰️', '👽', '🌟'];
		const movesEl = document.getElementById('mem-moves');
		const pairsEl = document.getElementById('mem-pairs');
		const statusEl = document.getElementById('mem-status');
		let deck, first, lock, moves, pairs, resetTimer;

		function reset() {
			// A mismatch-reset timeout from a previous game closes over the old deck/cards;
			// clear it so it can't blank a freshly flipped card in the new game.
			clearTimeout(resetTimer);
			deck = [...ICONS, ...ICONS].map((v) => ({ v, matched: false }));
			for (let i = deck.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [deck[i], deck[j]] = [deck[j], deck[i]]; }
			first = null; lock = false; moves = 0; pairs = 0;
			movesEl.textContent = '0'; pairsEl.textContent = '0'; statusEl.textContent = 'Find the pairs';
			board.innerHTML = '';
			deck.forEach((card, i) => {
				const b = document.createElement('button');
				b.className = 'flex aspect-square items-center justify-center rounded-md border bg-card text-2xl';
				b.textContent = '';
				b.dataset.i = String(i);
				b.addEventListener('click', () => flip(i, b));
				board.appendChild(b);
				card.el = b;
			});
		}
		function flip(i, b) {
			if (lock || deck[i].matched || b.textContent) return;
			b.textContent = deck[i].v;
			// first holds a card index that can legitimately be 0, so compare to null —
			// `!first` would treat card 0 as "no first card" and corrupt the turn state.
			if (first === null) { first = i; return; }
			moves++; movesEl.textContent = String(moves);
			if (deck[first].v === deck[i].v) {
				deck[first].matched = deck[i].matched = true;
				first = null; pairs++; pairsEl.textContent = String(pairs);
				if (pairs === ICONS.length) { statusEl.textContent = `Solved in ${moves} moves! 🎉`; if (window.ArmadaHighScores) window.ArmadaHighScores.recordScore('memory', moves, { lowerIsBetter: true }); }
			} else {
				lock = true;
				const f = first; first = null;
				resetTimer = setTimeout(() => { deck[f].el.textContent = ''; b.textContent = ''; lock = false; }, 700);
			}
		}
		document.getElementById('mem-reset').addEventListener('click', reset);
		reset();
	})();
</script>
