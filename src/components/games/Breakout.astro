---
import GameShell from './GameShell.astro';
import Leaderboard from './Leaderboard.astro';
---

<GameShell
	id="breakout"
	title="Breakout"
	instructions="Move the paddle with the Left/Right arrows or by moving your mouse/finger. Clear all the bricks. You have 3 lives."
>
	<canvas
		id="breakout-canvas"
		width="320"
		height="360"
		class="w-full max-w-[320px] touch-none rounded-md border bg-background"
	></canvas>
	<p class="text-sm font-medium">Score: <span id="breakout-score">0</span> · Lives: <span id="breakout-lives">3</span> · <span id="breakout-status">Move to start</span></p>
	<button id="breakout-reset" class="rounded-md border bg-background px-4 py-2 text-sm font-medium hover:bg-accent">Restart</button>
	<Leaderboard game="breakout" />
</GameShell>

<script is:inline>
	(() => {
		const canvas = document.getElementById('breakout-canvas');
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		const W = canvas.width, H = canvas.height;
		const scoreEl = document.getElementById('breakout-score');
		const livesEl = document.getElementById('breakout-lives');
		const statusEl = document.getElementById('breakout-status');
		const COLS = 8, ROWS = 4, BW = W / COLS, BH = 18;
		let paddle, ball, bricks, score, lives, started, over, raf;

		function reset() {
			paddle = { x: W / 2 - 32, w: 64, h: 10 };
			ball = { x: W / 2, y: H - 40, dx: 2.5, dy: -2.5, r: 6 };
			bricks = [];
			for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) bricks.push({ c, r, alive: true });
			score = 0; lives = 3; started = false; over = false;
			scoreEl.textContent = '0'; livesEl.textContent = '3';
			statusEl.textContent = 'Move to start';
			draw();
		}
		function start() { if (!started && !over) { started = true; statusEl.textContent = 'Playing…'; loop(); } }
		function loop() {
			if (over || !started) return;
			ball.x += ball.dx; ball.y += ball.dy;
			if (ball.x < ball.r || ball.x > W - ball.r) ball.dx *= -1;
			if (ball.y < ball.r) ball.dy *= -1;
			if (ball.y > H - 20 - ball.r && ball.x > paddle.x && ball.x < paddle.x + paddle.w && ball.dy > 0) {
				ball.dy *= -1;
				ball.dx += ((ball.x - (paddle.x + paddle.w / 2)) / paddle.w) * 2;
			}
			for (const b of bricks) {
				if (!b.alive) continue;
				const bx = b.c * BW, by = 30 + b.r * (BH + 4);
				if (ball.x > bx && ball.x < bx + BW - 2 && ball.y > by && ball.y < by + BH) {
					b.alive = false; ball.dy *= -1; score += 10; scoreEl.textContent = String(score);
					if (bricks.every((br) => !br.alive)) { over = true; statusEl.textContent = 'You cleared it! 🎉'; if (window.ArmadaHighScores) window.ArmadaHighScores.recordScore('breakout', score, { lowerIsBetter: false }); }
					break; // one bounce per frame — stops the ball tunnelling through two bricks at once
				}
			}
			if (ball.y > H) {
				lives--; livesEl.textContent = String(lives);
				if (lives <= 0) { over = true; statusEl.textContent = 'Game over! Press Restart.'; if (score > 0 && window.ArmadaHighScores) window.ArmadaHighScores.recordScore('breakout', score, { lowerIsBetter: false }); }
				else { ball = { x: W / 2, y: H - 40, dx: 2.5, dy: -2.5, r: 6 }; started = false; statusEl.textContent = 'Move to continue'; draw(); return; }
			}
			draw();
			if (!over) raf = requestAnimationFrame(loop);
		}
		function draw() {
			ctx.fillStyle = '#0b1020'; ctx.fillRect(0, 0, W, H);
			const colors = ['#ef4444', '#f59e0b', '#22c55e', '#3b82f6'];
			bricks.forEach((b) => { if (b.alive) { ctx.fillStyle = colors[b.r]; ctx.fillRect(b.c * BW + 1, 30 + b.r * (BH + 4), BW - 2, BH); } });
			ctx.fillStyle = '#e5e7eb'; ctx.fillRect(paddle.x, H - 20, paddle.w, paddle.h);
			ctx.fillStyle = '#f59e0b'; ctx.beginPath(); ctx.arc(ball.x, ball.y, ball.r, 0, Math.PI * 2); ctx.fill();
		}
		function movePaddle(x) { paddle.x = Math.max(0, Math.min(W - paddle.w, x - paddle.w / 2)); if (!started) draw(); }
		canvas.setAttribute('tabindex', '0');
		canvas.addEventListener('keydown', (e) => {
			if (e.key === 'ArrowLeft') { e.preventDefault(); start(); movePaddle(paddle.x + paddle.w / 2 - 24); }
			else if (e.key === 'ArrowRight') { e.preventDefault(); start(); movePaddle(paddle.x + paddle.w / 2 + 24); }
		});
		function pointerMove(e) {
			const rect = canvas.getBoundingClientRect();
			const cx = (e.touches ? e.touches[0].clientX : e.clientX) - rect.left;
			start(); movePaddle(cx * (W / rect.width));
		}
		canvas.addEventListener('mousemove', pointerMove);
		canvas.addEventListener('touchmove', (e) => { e.preventDefault(); pointerMove(e); }, { passive: false });
		canvas.addEventListener('pointerdown', () => { canvas.focus(); start(); });
		document.getElementById('breakout-reset').addEventListener('click', () => { cancelAnimationFrame(raf); reset(); });
		// ClientRouter (<ClientRouter />) swaps the DOM without a full reload; tear the
		// RAF loop down before the swap so it can't keep drawing to a detached canvas.
		document.addEventListener('astro:before-swap', () => {
			over = true; started = false; cancelAnimationFrame(raf);
		}, { once: true });
		reset();
	})();
</script>
