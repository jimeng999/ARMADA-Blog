---
import GameShell from './GameShell.astro';
import Leaderboard from './Leaderboard.astro';
---

<GameShell
	id="game2048"
	title="2048"
	instructions="Arrow keys (or swipe on touch) to slide tiles. Matching tiles merge. Reach 2048 to win."
>
	<div id="g2048-board" class="grid grid-cols-4 gap-2 rounded-md border bg-muted p-2 touch-none select-none" style="width:16rem;height:16rem"></div>
	<p class="text-sm font-medium">Score: <span id="g2048-score">0</span> · <span id="g2048-status">Use arrows / swipe</span></p>
	<button id="g2048-reset" class="rounded-md border bg-background px-4 py-2 text-sm font-medium hover:bg-accent">New game</button>
	<Leaderboard game="game2048" />
</GameShell>

<script is:inline>
	(() => {
		const board = document.getElementById('g2048-board');
		if (!board) return;
		const scoreEl = document.getElementById('g2048-score');
		const statusEl = document.getElementById('g2048-status');
		const COLORS = { 2: '#eee4da', 4: '#ede0c8', 8: '#f2b179', 16: '#f59563', 32: '#f67c5f', 64: '#f65e3b', 128: '#edcf72', 256: '#edcc61', 512: '#edc850', 1024: '#edc53f', 2048: '#edc22e' };
		let grid, score, over, won;

		function reset() {
			grid = Array.from({ length: 4 }, () => Array(4).fill(0));
			score = 0; over = false; won = false;
			scoreEl.textContent = '0'; statusEl.textContent = 'Use arrows / swipe';
			add(); add(); render();
		}
		function add() {
			const empty = [];
			grid.forEach((r, y) => r.forEach((v, x) => { if (!v) empty.push([x, y]); }));
			if (!empty.length) return;
			const [x, y] = empty[Math.floor(Math.random() * empty.length)];
			grid[y][x] = Math.random() < 0.9 ? 2 : 4;
		}
		function render() {
			board.innerHTML = '';
			for (let y = 0; y < 4; y++)
				for (let x = 0; x < 4; x++) {
					const v = grid[y][x];
					const cell = document.createElement('div');
					cell.className = 'flex items-center justify-center rounded-md text-lg font-bold';
					cell.style.background = v ? (COLORS[v] || '#3c3a32') : 'rgba(238,228,218,0.35)';
					cell.style.color = v <= 4 ? '#776e65' : '#f9f6f2';
					cell.textContent = v ? String(v) : '';
					board.appendChild(cell);
				}
		}
		function slide(row) {
			let arr = row.filter((v) => v);
			for (let i = 0; i < arr.length - 1; i++)
				if (arr[i] === arr[i + 1]) { arr[i] *= 2; score += arr[i]; if (arr[i] === 2048) won = true; arr.splice(i + 1, 1); }
			while (arr.length < 4) arr.push(0);
			return arr;
		}
		function move(dir) {
			if (over) return;
			const before = JSON.stringify(grid);
			const rot = (g) => g[0].map((_, i) => g.map((r) => r[i]));
			if (dir === 'left') grid = grid.map(slide);
			else if (dir === 'right') grid = grid.map((r) => slide(r.reverse()).reverse());
			else if (dir === 'up') { let g = rot(grid).map(slide); grid = rot(g); }
			else if (dir === 'down') { let g = rot(grid).map((r) => slide(r.reverse()).reverse()); grid = rot(g); }
			if (JSON.stringify(grid) === before) return;
			add(); scoreEl.textContent = String(score); render();
			if (won) { statusEl.textContent = 'You reached 2048! 🎉'; over = true; if (window.ArmadaHighScores) window.ArmadaHighScores.recordScore('game2048', score, { lowerIsBetter: false }); return; }
			if (!canMove()) { over = true; statusEl.textContent = 'Game over! No moves left.'; if (score > 0 && window.ArmadaHighScores) window.ArmadaHighScores.recordScore('game2048', score, { lowerIsBetter: false }); }
		}
		function canMove() {
			for (let y = 0; y < 4; y++)
				for (let x = 0; x < 4; x++) {
					if (!grid[y][x]) return true;
					if (x < 3 && grid[y][x] === grid[y][x + 1]) return true;
					if (y < 3 && grid[y][x] === grid[y + 1][x]) return true;
				}
			return false;
		}
		const keymap = { ArrowLeft: 'left', ArrowRight: 'right', ArrowUp: 'up', ArrowDown: 'down' };
		board.setAttribute('tabindex', '0');
		board.addEventListener('keydown', (e) => { if (keymap[e.key]) { e.preventDefault(); move(keymap[e.key]); } });
		board.addEventListener('pointerdown', () => board.focus());
		let sx, sy;
		board.addEventListener('touchstart', (e) => { sx = e.touches[0].clientX; sy = e.touches[0].clientY; }, { passive: true });
		board.addEventListener('touchend', (e) => {
			const dx = e.changedTouches[0].clientX - sx, dy = e.changedTouches[0].clientY - sy;
			if (Math.abs(dx) < 20 && Math.abs(dy) < 20) return;
			move(Math.abs(dx) > Math.abs(dy) ? (dx > 0 ? 'right' : 'left') : (dy > 0 ? 'down' : 'up'));
		});
		document.getElementById('g2048-reset').addEventListener('click', reset);
		reset();
	})();
</script>
