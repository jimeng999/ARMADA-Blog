---
import GameShell from './GameShell.astro';
import Leaderboard from './Leaderboard.astro';
---

<GameShell
	id="whackakraken"
	title="Whack-a-Kraken"
	instructions="Kraken tentacles surface from the portholes — tap or click one before it slips back under. Score as many strikes as you can before the timer runs out; the deep gets faster the longer you survive. Use number keys 1–9 (grid order) to strike with the keyboard."
>
	<div class="flex w-full max-w-md flex-col gap-4">
		<div class="flex items-center justify-between gap-4 text-sm font-medium">
			<span>Score: <span id="wak-score" class="tabular-nums font-bold">0</span></span>
			<span>Best: <span id="wak-best" class="tabular-nums font-bold">0</span></span>
			<span>Time: <span id="wak-time" class="tabular-nums font-bold">30</span>s</span>
		</div>

		<div class="flex items-center justify-center text-xs font-medium text-muted-foreground">
			<span
				id="wak-skill-issue"
				title="Every missed strike is, respectfully, a skill issue."
			>skill issue: <span id="wak-skill-count" class="tabular-nums font-bold text-red-500">0</span></span>
		</div>

		<div class="relative">
			<div
				id="wak-grid"
				class="relative grid touch-none grid-cols-3 gap-2 rounded-xl border bg-background p-2 select-none"
				role="grid"
				aria-label="Whack-a-Kraken — strike the tentacles"
			></div>

			<!-- Combo / hot-streak toast (good-natured, self-directed). -->
			<div
				id="wak-toast"
				class="pointer-events-none absolute top-2 left-1/2 z-10 -translate-x-1/2 rounded-full border border-amber-400/60 bg-amber-100/95 px-3 py-1 text-sm font-bold text-amber-900 opacity-0 shadow-lg"
				role="status"
				aria-live="polite"
			></div>

			<!-- "Touch grass" rage-quit overlay, shown after 3 consecutive whiffs. -->
			<div
				id="wak-overlay"
				class="absolute inset-0 z-20 hidden flex-col items-center justify-center gap-4 rounded-xl bg-background/95 p-4 text-center backdrop-blur-sm"
				role="dialog"
				aria-modal="true"
				aria-labelledby="wak-overlay-title"
				aria-hidden="true"
			>
				<div id="wak-overlay-emoji" class="text-5xl" aria-hidden="true">🌱</div>
				<p id="wak-overlay-title" class="text-lg font-bold">Maybe touch grass? 🌱</p>
				<p id="wak-overlay-sub" class="max-w-xs text-sm text-muted-foreground">
					Three whiffs in a row. The kraken sends its regards. No shame — the deep is undefeated.
				</p>
				<div class="flex flex-wrap items-center justify-center gap-2">
					<button
						id="wak-overlay-keep"
						class="rounded-md border bg-background px-4 py-2 text-sm font-medium hover:bg-accent"
					>Keep diving</button>
					<button
						id="wak-overlay-restart"
						class="rounded-md border bg-background px-4 py-2 text-sm font-medium hover:bg-accent"
					>Restart</button>
				</div>
			</div>
		</div>

		<div class="flex items-center justify-center gap-3">
			<button
				id="wak-btn"
				class="rounded-md border bg-background px-4 py-2 text-sm font-medium hover:bg-accent"
			>Start</button>
		</div>

		<p id="wak-status" class="text-center text-sm text-muted-foreground" role="status">
			Press Start to release the kraken.
		</p>

		<div class="flex justify-center">
			<Leaderboard game="whackakraken" />
		</div>
	</div>
</GameShell>

<style is:global>
	/* The cells and tentacles inside #wak-grid are created at runtime by the
	   inline script below, so they never receive Astro's scoped-style data
	   attribute — a scoped <style> block would not match them and every porthole
	   would render its tentacle permanently (issue #60). These rules are
	   therefore global, but namespaced under #wak-grid so they stay isolated to
	   this game. Each cell is a porthole; the tentacle hides below the waterline
	   and rises when active. prefers-reduced-motion swaps the transition for an
	   instant show/hide so nothing slides or pulses. */
	#wak-grid .wak-cell {
		position: relative;
		aspect-ratio: 1 / 1;
		overflow: hidden;
		border-radius: 9999px;
		border: 2px solid oklch(0.55 0.06 235 / 0.6);
		background:
			radial-gradient(circle at 50% 30%, oklch(0.42 0.07 240), oklch(0.22 0.05 250));
		cursor: pointer;
	}
	#wak-grid .wak-cell:focus-visible {
		outline: 2px solid oklch(0.78 0.18 78);
		outline-offset: 2px;
	}
	#wak-grid .wak-tentacle {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		color: oklch(0.55 0.16 18);
		transform: translateY(105%);
		transition: transform 140ms cubic-bezier(0.22, 1, 0.36, 1);
		will-change: transform;
	}
	#wak-grid .wak-cell.is-up .wak-tentacle {
		transform: translateY(0%);
	}
	#wak-grid .wak-cell.is-hit {
		animation: wak-flash 220ms ease-out;
	}
	#wak-grid .wak-tentacle svg {
		width: 78%;
		height: 90%;
	}
	@keyframes wak-flash {
		0% { background:
			radial-gradient(circle at 50% 30%, oklch(0.85 0.16 80), oklch(0.5 0.12 60)); }
		100% { background:
			radial-gradient(circle at 50% 30%, oklch(0.42 0.07 240), oklch(0.22 0.05 250)); }
	}
	/* Comedic taunt sign: a tiny placard that pops up over a surfaced kraken and
	   ducks back. Self-directed ribbing only — all copy is set from the script. */
	#wak-grid .wak-taunt {
		position: absolute;
		top: 4%;
		left: 50%;
		z-index: 5;
		padding: 1px 6px;
		border-radius: 9999px;
		border: 1px solid oklch(0.78 0.18 78 / 0.8);
		background: oklch(0.98 0.02 95);
		color: oklch(0.3 0.05 250);
		font-size: 0.62rem;
		font-weight: 700;
		line-height: 1.3;
		white-space: nowrap;
		pointer-events: none;
		transform: translate(-50%, -6px) scale(0.6);
		opacity: 0;
		transition: transform 160ms cubic-bezier(0.22, 1, 0.36, 1), opacity 160ms ease-out;
	}
	#wak-grid .wak-cell.is-taunting .wak-taunt {
		transform: translate(-50%, 0) scale(1);
		opacity: 1;
	}
	/* Toast slide/fade in. */
	#wak-toast.is-shown {
		opacity: 1;
		transition: opacity 180ms ease-out, transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
		transform: translate(-50%, 4px);
	}
	#wak-overlay.is-open { display: flex; }
	@media (prefers-reduced-motion: reduce) {
		#wak-grid .wak-taunt { transition: none; }
		#wak-toast.is-shown { transition: opacity 1ms linear; transform: translate(-50%, 0); }
	}
	/* Calm, accessible mode: no sliding, no flash — just appear/disappear. */
	@media (prefers-reduced-motion: reduce) {
		#wak-grid .wak-tentacle {
			transition: none;
			transform: translateY(0%);
			opacity: 0;
		}
		#wak-grid .wak-cell.is-up .wak-tentacle { opacity: 1; }
		#wak-grid .wak-cell.is-hit { animation: none; }
	}
</style>

<script is:inline>
	(() => {
		const grid = document.getElementById('wak-grid');
		if (!grid) return;
		const scoreEl = document.getElementById('wak-score');
		const bestEl = document.getElementById('wak-best');
		const timeEl = document.getElementById('wak-time');
		const btn = document.getElementById('wak-btn');
		const statusEl = document.getElementById('wak-status');
		const skillCountEl = document.getElementById('wak-skill-count');
		const toastEl = document.getElementById('wak-toast');
		const overlayEl = document.getElementById('wak-overlay');
		const overlayKeepBtn = document.getElementById('wak-overlay-keep');
		const overlayRestartBtn = document.getElementById('wak-overlay-restart');

		const COLS = 3, ROWS = 3, CELLS = COLS * ROWS;
		const GAME_SECONDS = 30;
		const BEST_KEY = 'wak-best';
		const MISS_LIMIT = 3;        // consecutive whiffs that trigger the overlay
		const COMBO_THRESHOLD = 4;   // hits in a row before a hot-streak toast
		const TAUNT_CHANCE = 0.28;   // chance a surfaced kraken flashes a taunt sign

		// PG, self-directed game taunts only — no slurs, no hate, no real people.
		const TAUNTS = ["you're mid", 'skill issue', 'too slow', 'whiff city', 'get good (kindly)'];
		const COMBO_TOASTS = ['ate, no crumbs 🔥', 'on a heater 🔥', 'cracked 🔥', 'no notes 🔥', 'locked in 🔥'];

		// Maritime tentacle art reused from the kraken easter-egg style.
		const TENTACLE_SVG =
			'<svg viewBox="0 0 200 200" aria-hidden="true" focusable="false">' +
			'<path fill="currentColor" d="M70 200 C 55 130 95 110 80 60 C 72 30 50 30 45 0 C 70 30 95 45 100 95 C 105 150 92 175 100 200 Z" />' +
			'<path fill="currentColor" d="M130 200 C 145 130 105 110 120 60 C 128 30 150 30 155 0 C 130 30 105 45 100 95 C 95 150 108 175 100 200 Z" />' +
			'<circle cx="82" cy="78" r="9" fill="oklch(0.95 0.16 95)" />' +
			'<circle cx="118" cy="78" r="9" fill="oklch(0.95 0.16 95)" />' +
			'<circle cx="82" cy="80" r="4" fill="oklch(0.18 0.04 252)" />' +
			'<circle cx="118" cy="80" r="4" fill="oklch(0.18 0.04 252)" />' +
			'</svg>';

		const reduceMotion = window.matchMedia
			? window.matchMedia('(prefers-reduced-motion: reduce)').matches
			: false;

		let cells = [];
		let active = -1;       // index of the currently-surfaced tentacle, or -1
		let score = 0;
		let timeLeft = GAME_SECONDS;
		let running = false;
		let spawnTimer = null;
		let hideTimer = null;
		let countdownTimer = null;
		let best = 0;
		let missStreak = 0;     // consecutive whiffs (resets on any hit)
		let hitStreak = 0;      // consecutive hits (resets on any whiff)
		let skillIssues = 0;    // total whiffs this run — the "skill issue" tally
		let nextComboAt = COMBO_THRESHOLD; // streak length for the next toast
		let toastTimer = null;
		let tauntTimer = null;
		let overlayOpen = false;

		try { best = parseInt(localStorage.getItem(BEST_KEY) || '0', 10) || 0; } catch (e) {}
		bestEl.textContent = String(best);

		function buildGrid() {
			grid.innerHTML = '';
			cells = [];
			for (let i = 0; i < CELLS; i++) {
				const cell = document.createElement('button');
				cell.type = 'button';
				cell.className = 'wak-cell';
				cell.setAttribute('aria-label', `Porthole ${i + 1}`);
				cell.innerHTML = '<span class="wak-tentacle">' + TENTACLE_SVG + '</span>' +
					'<span class="wak-taunt" aria-hidden="true"></span>';
				cell.addEventListener('pointerdown', (e) => { e.preventDefault(); strike(i); });
				grid.appendChild(cell);
				cells.push(cell);
			}
		}

		// Difficulty ramps with elapsed time: spawn window shrinks from ~1000ms
		// down toward ~420ms as the clock runs down.
		function currentWindow() {
			const elapsed = GAME_SECONDS - timeLeft;
			const t = Math.min(1, elapsed / GAME_SECONDS);
			return Math.round(1000 - t * 580); // 1000ms → 420ms
		}

		function clearActive() {
			if (active >= 0) {
				cells[active].classList.remove('is-up', 'is-taunting');
				active = -1;
			}
		}

		// Occasionally a surfaced kraken flashes a tiny placard then ducks back.
		function maybeTaunt(idx) {
			clearTimeout(tauntTimer);
			if (Math.random() > TAUNT_CHANCE) return;
			const cell = cells[idx];
			const sign = cell && cell.querySelector('.wak-taunt');
			if (!sign) return;
			sign.textContent = TAUNTS[Math.floor(Math.random() * TAUNTS.length)];
			cell.classList.add('is-taunting');
			// Duck the sign back under before the porthole itself hides.
			tauntTimer = setTimeout(() => { cell.classList.remove('is-taunting'); }, 700);
		}

		function showToast(msg) {
			if (!toastEl) return;
			clearTimeout(toastTimer);
			toastEl.textContent = msg;
			toastEl.classList.add('is-shown');
			toastTimer = setTimeout(() => { toastEl.classList.remove('is-shown'); }, 1300);
		}

		function bumpSkillIssue() {
			skillIssues++;
			if (skillCountEl) skillCountEl.textContent = String(skillIssues);
		}

		function openOverlay() {
			if (!overlayEl) return;
			overlayOpen = true;
			overlayEl.classList.add('is-open');
			overlayEl.setAttribute('aria-hidden', 'false');
			// Pause spawning while the sailor considers the great outdoors.
			clearTimeout(spawnTimer);
			clearTimeout(hideTimer);
			clearActive();
			if (overlayKeepBtn) overlayKeepBtn.focus();
		}

		function closeOverlay() {
			if (!overlayEl) return;
			overlayOpen = false;
			overlayEl.classList.remove('is-open');
			overlayEl.setAttribute('aria-hidden', 'true');
		}

		function spawn() {
			if (!running) return;
			clearActive();
			// Choose a random cell (any cell is fine since the previous one is down).
			const idx = Math.floor(Math.random() * CELLS);
			active = idx;
			cells[idx].classList.add('is-up');
			maybeTaunt(idx);
			const win = currentWindow();
			hideTimer = setTimeout(() => {
				clearActive();
				// Short gap before the next surfacing keeps it readable.
				spawnTimer = setTimeout(spawn, reduceMotion ? 260 : 160);
			}, win);
		}

		function strike(i) {
			if (!running || overlayOpen) return;
			if (i !== active) {
				// Missed / empty porthole — no points, but it's a "skill issue".
				whiff();
				return;
			}
			cells[i].classList.remove('is-up', 'is-taunting');
			cells[i].classList.add('is-hit');
			setTimeout(() => cells[i] && cells[i].classList.remove('is-hit'), 240);
			active = -1;
			score++;
			scoreEl.textContent = String(score);
			// A clean strike resets the whiff streak and feeds the combo meter.
			missStreak = 0;
			hitStreak++;
			if (hitStreak >= nextComboAt) {
				showToast(COMBO_TOASTS[Math.floor(Math.random() * COMBO_TOASTS.length)]);
				nextComboAt = hitStreak + COMBO_THRESHOLD; // next toast a few hits later
			}
			clearTimeout(hideTimer);
			// Immediately surface the next one for a snappy combo feel.
			spawnTimer = setTimeout(spawn, reduceMotion ? 220 : 120);
		}

		// A whiff: a tap that hit no kraken. Counts toward the skill-issue tally
		// and the consecutive-miss streak that triggers the "touch grass" overlay.
		function whiff() {
			hitStreak = 0;
			nextComboAt = COMBO_THRESHOLD;
			bumpSkillIssue();
			missStreak++;
			if (missStreak >= MISS_LIMIT) {
				missStreak = 0;
				openOverlay();
			}
		}

		function tick() {
			timeLeft--;
			timeEl.textContent = String(Math.max(0, timeLeft));
			if (timeLeft <= 0) finish();
		}

		function start() {
			stopTimers();
			closeOverlay();
			score = 0;
			timeLeft = GAME_SECONDS;
			running = true;
			missStreak = 0;
			hitStreak = 0;
			skillIssues = 0;
			nextComboAt = COMBO_THRESHOLD;
			if (skillCountEl) skillCountEl.textContent = '0';
			if (toastEl) toastEl.classList.remove('is-shown');
			scoreEl.textContent = '0';
			timeEl.textContent = String(GAME_SECONDS);
			statusEl.textContent = 'Strike! The kraken surfaces…';
			btn.textContent = 'Restart';
			buildGrid();
			countdownTimer = setInterval(tick, 1000);
			spawn();
		}

		function finish() {
			running = false;
			stopTimers();
			closeOverlay();
			clearActive();
			if (score > best) {
				best = score;
				bestEl.textContent = String(best);
				try { localStorage.setItem(BEST_KEY, String(best)); } catch (e) {}
				statusEl.textContent = `Game over — new best of ${score}! Press Restart to dive again.`;
			} else {
				statusEl.textContent = `Game over — you struck ${score}. Press Restart to dive again.`;
			}
			if (score > 0 && window.ArmadaHighScores)
				window.ArmadaHighScores.recordScore('whackakraken', score, { lowerIsBetter: false });
			btn.textContent = 'Restart';
		}

		function stopTimers() {
			clearTimeout(spawnTimer);
			clearTimeout(hideTimer);
			clearInterval(countdownTimer);
			clearTimeout(toastTimer);
			clearTimeout(tauntTimer);
			spawnTimer = hideTimer = countdownTimer = toastTimer = tauntTimer = null;
		}

		// "Keep diving" — dismiss the overlay and resume play where we left off.
		function resumeFromOverlay() {
			closeOverlay();
			if (!running) return;
			statusEl.textContent = 'Back to the brine — strike!';
			clearTimeout(spawnTimer);
			spawnTimer = setTimeout(spawn, reduceMotion ? 220 : 120);
		}

		btn.addEventListener('click', start);
		if (overlayKeepBtn) overlayKeepBtn.addEventListener('click', resumeFromOverlay);
		if (overlayRestartBtn) overlayRestartBtn.addEventListener('click', start);

		// Keyboard play: number keys 1–9 strike the matching porthole.
		document.addEventListener('keydown', (e) => {
			if (overlayOpen && e.key === 'Escape') {
				e.preventDefault();
				resumeFromOverlay();
				return;
			}
			if (!running || overlayOpen) return;
			const n = parseInt(e.key, 10);
			if (!Number.isNaN(n) && n >= 1 && n <= CELLS) {
				e.preventDefault();
				strike(n - 1);
			}
		});

		// Clean up on Astro route swaps so timers don't leak across pages.
		document.addEventListener('astro:before-swap', () => { running = false; stopTimers(); }, { once: true });

		buildGrid();
	})();
</script>
