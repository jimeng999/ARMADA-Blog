---
import GameShell from './GameShell.astro';
import Leaderboard from './Leaderboard.astro';
---

<GameShell
	id="snake"
	title="Snake"
	instructions="Arrow keys (or WASD) to steer. On touch use the buttons. Eat the food, don't hit the walls or yourself."
>
	<canvas
		id="snake-canvas"
		width="300"
		height="300"
		class="w-full max-w-[300px] touch-none rounded-md border bg-background"
	></canvas>
	<p class="text-sm font-medium">Score: <span id="snake-score">0</span> · <span id="snake-status">Press an arrow key to start</span></p>
	<div class="grid grid-cols-3 gap-2 sm:hidden" style="width:9rem">
		<span></span>
		<button data-snake-dir="up" class="rounded-md border bg-background px-3 py-2 text-sm">▲</button>
		<span></span>
		<button data-snake-dir="left" class="rounded-md border bg-background px-3 py-2 text-sm">◀</button>
		<button data-snake-dir="down" class="rounded-md border bg-background px-3 py-2 text-sm">▼</button>
		<button data-snake-dir="right" class="rounded-md border bg-background px-3 py-2 text-sm">▶</button>
	</div>
	<button id="snake-reset" class="rounded-md border bg-background px-4 py-2 text-sm font-medium hover:bg-accent">Restart</button>
	<Leaderboard game="snake" />
</GameShell>

<script is:inline>
	(() => {
		const canvas = document.getElementById('snake-canvas');
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		const N = 15, S = canvas.width / N;
		const scoreEl = document.getElementById('snake-score');
		const statusEl = document.getElementById('snake-status');
		let snake, dir, next, food, score, over, started, stepTimer;

		function reset() {
			snake = [{ x: 7, y: 7 }]; dir = { x: 0, y: 0 }; next = { x: 0, y: 0 };
			score = 0; over = false; started = false;
			scoreEl.textContent = '0';
			statusEl.textContent = 'Press an arrow key to start';
			placeFood(); draw();
		}
		function placeFood() {
			do { food = { x: Math.floor(Math.random() * N), y: Math.floor(Math.random() * N) }; }
			while (snake.some((s) => s.x === food.x && s.y === food.y));
		}
		function setDir(x, y) {
			if (over) return;
			if (x === -dir.x && y === -dir.y && snake.length > 1) return;
			next = { x, y };
			if (!started && (x || y)) { started = true; statusEl.textContent = 'Playing…'; }
		}
		function step() {
			if (over || !started) return;
			dir = next;
			const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };
			const eats = head.x === food.x && head.y === food.y;
			// On a non-eating move the tail vacates this tick, so the cell it leaves is free to
			// enter — exclude the last segment from the self-collision test unless we're growing.
			const body = eats ? snake : snake.slice(0, -1);
			if (head.x < 0 || head.x >= N || head.y < 0 || head.y >= N || body.some((s) => s.x === head.x && s.y === head.y)) {
				over = true; started = false; statusEl.textContent = 'Game over! Press Restart.';
				if (score > 0 && window.ArmadaHighScores) window.ArmadaHighScores.recordScore('snake', score, { lowerIsBetter: false });
				return;
			}
			snake.unshift(head);
			if (eats) {
				score++; scoreEl.textContent = String(score);
				// If the snake now fills every cell there is no free square for food — that's a win,
				// not an infinite placeFood() loop.
				if (snake.length >= N * N) {
					over = true; started = false; statusEl.textContent = 'You filled the board — you win! 🎉'; draw();
					if (window.ArmadaHighScores) window.ArmadaHighScores.recordScore('snake', score, { lowerIsBetter: false });
					return;
				}
				placeFood();
			} else snake.pop();
			draw();
		}
		function draw() {
			ctx.fillStyle = '#0b1020'; ctx.fillRect(0, 0, canvas.width, canvas.height);
			ctx.fillStyle = '#ef4444';
			ctx.fillRect(food.x * S + 2, food.y * S + 2, S - 4, S - 4);
			snake.forEach((s, i) => {
				ctx.fillStyle = i === 0 ? '#22c55e' : '#16a34a';
				ctx.fillRect(s.x * S + 1, s.y * S + 1, S - 2, S - 2);
			});
		}
		const keys = { ArrowUp: [0, -1], ArrowDown: [0, 1], ArrowLeft: [-1, 0], ArrowRight: [1, 0], w: [0, -1], s: [0, 1], a: [-1, 0], d: [1, 0] };
		canvas.setAttribute('tabindex', '0');
		canvas.addEventListener('keydown', (e) => {
			const k = keys[e.key];
			if (k) { e.preventDefault(); setDir(k[0], k[1]); }
		});
		canvas.addEventListener('pointerdown', () => canvas.focus());
		document.querySelectorAll('[data-snake-dir]').forEach((b) => b.addEventListener('click', () => {
			const m = { up: [0, -1], down: [0, 1], left: [-1, 0], right: [1, 0] }[b.getAttribute('data-snake-dir')];
			setDir(m[0], m[1]);
		}));
		document.getElementById('snake-reset').addEventListener('click', reset);
		// ClientRouter swaps the DOM without a full reload; stop the step timer before the swap
		// so it can't keep firing against the detached canvas (and can't stack on re-entry).
		document.addEventListener('astro:before-swap', () => { clearInterval(stepTimer); }, { once: true });
		reset();
		stepTimer = setInterval(step, 130);
	})();
</script>
