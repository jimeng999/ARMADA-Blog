---
// SpaceX (SPCX) stock-price chart — a fully client-side island.
//
// SpaceX IPO'd on the Nasdaq in June 2026 under the ticker SPCX. This island
// charts its real, post-IPO price by calling two keyless, CORS-enabled,
// browser-safe endpoints directly (no backend, no proxy, no API key, no
// account) — the same class of source the /gold page uses:
//   - latest quote (USD)   : https://stockanalysis.com/api/quotes/s/SPCX
//   - daily OHLC history   : https://stockanalysis.com/api/symbol/s/SPCX/history?range=…&period=Daily
//
// stockanalysis.com serves these with `Access-Control-Allow-Origin: *`, so a
// browser fetch from this origin succeeds without a proxy. Prices are the
// stock's real USD close — no conversion, no mocking. Because SPCX only began
// trading in June 2026, the available history is short and grows as the stock
// trades; the chart honestly reports when a selected range has too few points
// rather than padding it.
//
// The chart is hand-rolled SVG — no charting dependency — so the static Astro
// build stays lean. The script defensively validates every third-party response
// shape before rendering, keeps the last good chart on a refresh failure, tears
// down cleanly on client-side navigation, and never throws into the page.
---

<section
	id="spacex"
	class="flex scroll-mt-24 flex-col gap-6 rounded-xl border bg-card p-5 text-card-foreground shadow-sm sm:p-6"
	data-spacex-root
>
	<!-- Latest price — exposed as text (not only inside the chart) for a11y. -->
	<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
		<div class="flex flex-col gap-1">
			<h2 class="text-sm font-medium text-muted-foreground">Latest SpaceX price (SPCX)</h2>
			<p class="flex items-baseline gap-2">
				<span
					id="spacex-latest"
					class="font-serif text-3xl font-semibold tracking-tight tabular-nums sm:text-4xl"
					aria-live="polite"
				>—</span>
				<span id="spacex-latest-unit" class="text-sm text-muted-foreground">USD</span>
			</p>
			<p class="text-xs text-muted-foreground">
				<span id="spacex-updated">Loading latest price…</span>
			</p>
			<p class="text-xs text-muted-foreground">
				Indicative, delayed price — for information only, not investment advice.
			</p>
		</div>

		<!-- Day change — a plain text readout (no colour-only meaning: the sign and
		     an "up"/"down" word carry the direction, the tint is decorative). -->
		<div class="flex flex-col gap-1" data-spacex-change-wrap>
			<span class="text-xs font-medium text-muted-foreground">Change on the day</span>
			<span
				id="spacex-change"
				class="text-sm font-medium tabular-nums"
				aria-live="polite"
			>—</span>
		</div>
	</div>

	<!-- Range controls. Each is a real <button>; the active one is marked with
	     aria-pressed (not colour alone). The free history feed is daily, so
	     1W/1M/6M/1Y/5Y are all supported (windows are anchored to the most
	     recent available data point, which can lag "today"). Only 1D is disabled
	     — the free source has no intraday granularity — and its reason is shown
	     as always-visible text below (not hover-only title), so keyboard users
	     get it too. Because SPCX is newly listed, longer ranges may simply hold
	     all the history that exists so far. -->
	<div class="flex flex-col gap-2">
		<div
			class="flex flex-wrap gap-2"
			role="group"
			aria-label="Chart time range"
			data-spacex-ranges
		>
			<button type="button" data-spacex-range="1D" disabled aria-pressed="false"
				aria-describedby="spacex-disabled-note"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>1D</button>
			<button type="button" data-spacex-range="1W" aria-pressed="false"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>1W</button>
			<button type="button" data-spacex-range="1M" aria-pressed="false"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>1M</button>
			<button type="button" data-spacex-range="6M" aria-pressed="false"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>6M</button>
			<button type="button" data-spacex-range="1Y" aria-pressed="true"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>1Y</button>
			<button type="button" data-spacex-range="5Y" aria-pressed="false"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>5Y</button>
		</div>
		<p id="spacex-disabled-note" class="text-xs text-muted-foreground">
			1D (intraday) isn't available from the free source.
		</p>
		<p id="spacex-range-note" class="min-h-4 text-xs text-muted-foreground" aria-live="polite"></p>
	</div>

	<!-- Chart region. The SVG is responsive via viewBox; a text status sits
	     above it so loading/error are conveyed without relying on the graphic. -->
	<div class="flex flex-col gap-2">
		<p id="spacex-chart-status" class="text-sm text-muted-foreground" aria-live="polite">
			Loading price history…
		</p>
		<div
			class="relative w-full overflow-hidden rounded-md border bg-background"
			data-spacex-chart-wrap
		>
			<svg
				id="spacex-chart"
				viewBox="0 0 800 320"
				preserveAspectRatio="none"
				class="block h-[260px] w-full sm:h-[320px]"
				role="img"
				aria-label="Historical SpaceX (SPCX) stock price line chart in US dollars"
			></svg>
			<!-- Tooltip; hidden until hover/tap, position set by the script. It's a
			     pointer-only affordance updated on every move, so it is NOT an
			     aria-live region (no role=status) — that would spam SR users. -->
			<div
				id="spacex-tooltip"
				aria-hidden="true"
				class="pointer-events-none absolute z-10 hidden -translate-x-1/2 -translate-y-full rounded-md border bg-popover px-2 py-1 text-xs text-popover-foreground shadow-md"
			></div>
		</div>
		<p class="text-xs text-muted-foreground">
			Prices are the stock's daily closing price in US dollars from a free
			source, and can lag the current date by a few days. SpaceX (SPCX) only
			began trading in June 2026, so the available history is short for now and
			lengthens as the stock trades. Latest price refreshes every 5 minutes.
		</p>
		<!-- Visually-hidden data table: a keyboard/SR-accessible equivalent of the
		     pointer-only chart hover (the SVG itself isn't focusable). -->
		<div id="spacex-data-table" class="sr-only" aria-live="polite"></div>
	</div>
</section>

<script is:inline>
	(() => {
		const root = document.querySelector('[data-spacex-root]');
		if (!root || root.dataset.spacexBound === '1') return;
		root.dataset.spacexBound = '1';

		// ---- Endpoints (keyless, CORS-safe, browser-only) --------------------
		// stockanalysis.com serves these with Access-Control-Allow-Origin: * — no
		// key, no account, no proxy. SPCX is SpaceX's real post-IPO Nasdaq ticker.
		const QUOTE_URL = 'https://stockanalysis.com/api/quotes/s/SPCX';
		const histUrl = (apiRange) =>
			`https://stockanalysis.com/api/symbol/s/SPCX/history?range=${apiRange}&period=Daily`;
		const REFRESH_MS = 5 * 60 * 1000;
		const FETCH_TIMEOUT_MS = 12 * 1000; // a hung provider can't wedge the page
		// Plausible bounds (USD) to reject absurd values before they become
		// non-finite or off-canvas SVG coordinates.
		const MIN_USD = 0.01;
		const MAX_USD = 1_000_000;

		// Ranges with no free granular data — disabled in the markup; listed here
		// so the friendly "unavailable" note can name them if one is reached.
		// (Only 1D: the feed is daily, so 1W/1M/6M/1Y/5Y are all supported.)
		const UNAVAILABLE = { '1D': true };
		// Window length per range, in days. Anchored to the most recent available
		// data point (not "today"), since the free feed can lag the current date.
		const RANGE_DAYS = { '1W': 7, '1M': 31, '6M': 183, '1Y': 366, '5Y': 1827 };
		// Map our UI range to the API's range param so it returns enough rows.
		const API_RANGE = { '1W': '1M', '1M': '1M', '6M': '6M', '1Y': '1Y', '5Y': '5Y' };

		// ---- Elements --------------------------------------------------------
		const latestEl = root.querySelector('#spacex-latest');
		const updatedEl = root.querySelector('#spacex-updated');
		const changeEl = root.querySelector('#spacex-change');
		const chartEl = root.querySelector('#spacex-chart');
		const chartStatusEl = root.querySelector('#spacex-chart-status');
		const rangeNoteEl = root.querySelector('#spacex-range-note');
		const tooltipEl = root.querySelector('#spacex-tooltip');
		const chartWrap = root.querySelector('[data-spacex-chart-wrap]');
		const dataTableEl = root.querySelector('#spacex-data-table');
		const SVGNS = 'http://www.w3.org/2000/svg';

		// ---- State -----------------------------------------------------------
		let range = '1Y';
		let spotUsd = null; // latest price, USD
		let dayChange = null; // absolute change on the day, USD
		let dayChangePct = null; // percent change on the day
		let spotUpdatedAt = null; // string from the feed (e.g. "Jun 15, 2026, 4:00 PM EDT")
		let history = []; // [{ t: epochMs, usd: closeUsd }] sorted ascending
		const histCache = {}; // apiRange -> parsed history (avoid refetch on range toggles)
		let refreshTimer = null;
		let refreshing = false; // serialise refreshes — drop overlap (minor)
		let disposed = false; // set on client-side nav / unload; bail out of async work
		const inflight = new Set(); // AbortControllers for in-flight fetches

		// ---- Helpers ---------------------------------------------------------
		const isFiniteNum = (n) => typeof n === 'number' && isFinite(n);
		const inUsdRange = (n) => isFiniteNum(n) && n >= MIN_USD && n <= MAX_USD;

		const fmtUsd = (v) =>
			new Intl.NumberFormat('en-US', {
				style: 'currency',
				currency: 'USD',
				maximumFractionDigits: 2,
			}).format(v);

		// Historical dates are calendar days (YYYY-MM-DD parsed as UTC midnight);
		// render them in UTC so users west of UTC don't see them shift a day back.
		const fmtUtcDay = (t) =>
			new Date(t).toLocaleDateString('en-AU', { dateStyle: 'medium', timeZone: 'UTC' });

		// AbortController-based timeout so a hung endpoint can't stall the page;
		// also aborted en-masse on dispose (client-side nav / unload).
		async function getJson(url) {
			const ctrl = new AbortController();
			inflight.add(ctrl);
			const timer = setTimeout(() => ctrl.abort(), FETCH_TIMEOUT_MS);
			try {
				const res = await fetch(url, {
					headers: { accept: 'application/json' },
					signal: ctrl.signal,
				});
				if (!res.ok) throw new Error(`HTTP ${res.status}`);
				return await res.json();
			} finally {
				clearTimeout(timer);
				inflight.delete(ctrl);
			}
		}

		// ---- Render: latest price (text, not only in the chart) --------------
		function renderLatest() {
			if (!inUsdRange(spotUsd)) {
				latestEl.textContent = '—';
				return;
			}
			latestEl.textContent = fmtUsd(spotUsd);
			if (spotUpdatedAt) {
				updatedEl.textContent = `Last updated ${spotUpdatedAt} · delayed`;
			} else {
				updatedEl.textContent = 'Delayed price';
			}
			renderChange();
		}

		function renderChange() {
			if (!isFiniteNum(dayChange) || !isFiniteNum(dayChangePct)) {
				changeEl.textContent = '—';
				changeEl.classList.remove('text-emerald-600', 'text-red-600', 'dark:text-emerald-400', 'dark:text-red-400');
				return;
			}
			const up = dayChange >= 0;
			const sign = up ? '+' : '−';
			const dir = up ? 'up' : 'down';
			const amt = fmtUsd(Math.abs(dayChange));
			const pct = Math.abs(dayChangePct).toFixed(2);
			// Sign + word carry the meaning; colour is a decorative reinforcement.
			changeEl.textContent = `${sign}${amt} (${sign}${pct}%) ${dir} on the day`;
			changeEl.classList.toggle('text-emerald-600', up);
			changeEl.classList.toggle('dark:text-emerald-400', up);
			changeEl.classList.toggle('text-red-600', !up);
			changeEl.classList.toggle('dark:text-red-400', !up);
		}

		// ---- Render: the SVG line chart --------------------------------------
		// Window is anchored to the MOST RECENT available data point, not "today"
		// — the free feed can lag the current date by days, so a today-anchored
		// 1W/1M window would be empty even though recent data exists. No silent
		// out-of-range fallback: if a window genuinely lacks data we report that
		// (see renderChart), rather than plotting old points under a recent label.
		function visiblePoints() {
			const days = RANGE_DAYS[range];
			if (!days || !history.length) return [];
			const anchor = history[history.length - 1].t; // latest point's date
			const cutoff = anchor - days * 24 * 3600 * 1000;
			return history.filter((p) => p.t >= cutoff);
		}

		function clearChart() {
			while (chartEl.firstChild) chartEl.removeChild(chartEl.firstChild);
		}

		let chartGeom = null; // for hit-testing the tooltip

		function renderChart() {
			clearChart();
			tooltipEl.classList.add('hidden');
			chartGeom = null;

			if (UNAVAILABLE[range]) {
				// Only 1D reaches here (intraday, no free feed). 1W/1M are enabled.
				rangeNoteEl.textContent =
					`The ${range} view isn't available — the free source has no intraday data. Try 1W, 1M, 6M, 1Y or 5Y.`;
				chartStatusEl.textContent = 'Select 1W, 1M, 6M, 1Y or 5Y to view the chart.';
				renderDataTable([]);
				return;
			}
			rangeNoteEl.textContent = '';

			if (!history.length) {
				chartStatusEl.textContent = 'Price history is unavailable right now.';
				renderDataTable([]);
				return;
			}

			const pts = visiblePoints();
			if (pts.length < 2) {
				// No silent substitution of out-of-range points: say so plainly.
				// SPCX is newly listed, so a short window legitimately lacks points.
				const latest = history[history.length - 1];
				const asOf = fmtUtcDay(latest.t);
				chartStatusEl.textContent =
					`Not enough data in the ${range} window to draw a chart yet (SPCX is newly listed; latest point is ${asOf}). Try a longer range.`;
				renderDataTable([]);
				return;
			}

			const W = 800, H = 320, padL = 64, padR = 16, padT = 16, padB = 28;
			const vals = pts.map((p) => p.usd).filter(isFiniteNum);
			if (vals.length < 2) {
				chartStatusEl.textContent = 'Not enough price history to draw a chart for this range.';
				renderDataTable([]);
				return;
			}
			let min = Math.min(...vals);
			let max = Math.max(...vals);
			if (min === max) { min -= 1; max += 1; }
			const pad = (max - min) * 0.08;
			min -= pad; max += pad;

			const t0 = pts[0].t, t1 = pts[pts.length - 1].t;
			const span = Math.max(1, t1 - t0);
			const x = (t) => padL + ((t - t0) / span) * (W - padL - padR);
			const y = (v) => padT + (1 - (v - min) / (max - min)) * (H - padT - padB);

			const mk = (name, attrs) => {
				const el = document.createElementNS(SVGNS, name);
				for (const k in attrs) el.setAttribute(k, attrs[k]);
				return el;
			};

			// Y gridlines + labels (text labels, so values aren't colour-only).
			const ticks = 4;
			for (let i = 0; i <= ticks; i++) {
				const v = min + ((max - min) * i) / ticks;
				const gy = y(v);
				chartEl.appendChild(mk('line', {
					x1: padL, x2: W - padR, y1: gy, y2: gy,
					stroke: 'var(--border)', 'stroke-width': '1',
				}));
				const label = mk('text', {
					x: padL - 8, y: gy + 4, 'text-anchor': 'end',
					fill: 'var(--muted-foreground)', 'font-size': '12',
				});
				label.textContent = fmtUsd(v);
				chartEl.appendChild(label);
			}

			// X axis end labels. Year-only over long ranges, month+year when the
			// window is short enough that a bare year would be ambiguous. UTC, to
			// match how the calendar-day points were parsed.
			const spanDays = span / (24 * 3600 * 1000);
			const fmtAxis = (t) => {
				const d = new Date(t);
				return spanDays <= 800
					? d.toLocaleDateString('en-AU', { month: 'short', year: 'numeric', timeZone: 'UTC' })
					: d.toLocaleDateString('en-AU', { year: 'numeric', timeZone: 'UTC' });
			};
			const xs = mk('text', { x: padL, y: H - 8, 'text-anchor': 'start', fill: 'var(--muted-foreground)', 'font-size': '12' });
			xs.textContent = fmtAxis(t0);
			chartEl.appendChild(xs);
			const xe = mk('text', { x: W - padR, y: H - 8, 'text-anchor': 'end', fill: 'var(--muted-foreground)', 'font-size': '12' });
			xe.textContent = fmtAxis(t1);
			chartEl.appendChild(xe);

			// The line itself (brass/primary chart colour).
			const coords = pts.map((p) => ({ px: x(p.t), py: y(p.usd), t: p.t, usd: p.usd }));
			const d = coords.map((c, i) => `${i ? 'L' : 'M'}${c.px.toFixed(1)},${c.py.toFixed(1)}`).join(' ');
			chartEl.appendChild(mk('path', {
				d, fill: 'none', stroke: 'var(--chart-1)', 'stroke-width': '2.5',
				'stroke-linejoin': 'round', 'stroke-linecap': 'round',
			}));
			// Data dots — only for sparse series; a dense daily line would be noisy
			// with a dot per point, so dot just the endpoints there.
			const dotted = coords.length <= 24 ? coords : [coords[0], coords[coords.length - 1]];
			dotted.forEach((c) => {
				chartEl.appendChild(mk('circle', { cx: c.px, cy: c.py, r: '3', fill: 'var(--chart-1)' }));
			});

			chartGeom = { coords, W, H };
			chartStatusEl.textContent =
				`Showing ${pts.length} ${pts.length === 1 ? 'point' : 'points'} (${fmtUtcDay(t0)} – ${fmtUtcDay(t1)}), daily close in USD.`;
			renderDataTable(coords);
		}

		// ---- Accessible data table (keyboard/SR equivalent of the chart) -----
		// The SVG hover is pointer-only, so mirror the plotted points as a real
		// table in a visually-hidden, aria-live region.
		function renderDataTable(coords) {
			while (dataTableEl.firstChild) dataTableEl.removeChild(dataTableEl.firstChild);
			if (!coords || !coords.length) return;
			const table = document.createElement('table');
			const caption = document.createElement('caption');
			caption.textContent = `SpaceX (SPCX) price history (${range}), daily close in USD.`;
			table.appendChild(caption);
			const thead = document.createElement('thead');
			const hr = document.createElement('tr');
			['Date', 'Close (USD)'].forEach((h) => {
				const th = document.createElement('th');
				th.setAttribute('scope', 'col');
				th.textContent = h;
				hr.appendChild(th);
			});
			thead.appendChild(hr);
			table.appendChild(thead);
			const tbody = document.createElement('tbody');
			for (const c of coords) {
				if (!isFiniteNum(c.usd)) continue;
				const tr = document.createElement('tr');
				const td1 = document.createElement('td');
				td1.textContent = fmtUtcDay(c.t);
				const td2 = document.createElement('td');
				td2.textContent = fmtUsd(c.usd);
				tr.appendChild(td1);
				tr.appendChild(td2);
				tbody.appendChild(tr);
			}
			table.appendChild(tbody);
			dataTableEl.appendChild(table);
		}

		// ---- Tooltip (hover desktop / tap mobile) ----------------------------
		function showTooltipAt(clientX) {
			if (!chartGeom) return;
			const rect = chartEl.getBoundingClientRect();
			// Map pointer x into the SVG's 800-wide viewBox coordinate space.
			const vx = ((clientX - rect.left) / rect.width) * chartGeom.W;
			let nearest = null, best = Infinity;
			for (const c of chartGeom.coords) {
				const dist = Math.abs(c.px - vx);
				if (dist < best) { best = dist; nearest = c; }
			}
			if (!nearest || !isFiniteNum(nearest.usd)) return;
			const when = fmtUtcDay(nearest.t);
			tooltipEl.textContent = `${when}: ${fmtUsd(nearest.usd)}`;
			tooltipEl.classList.remove('hidden');
			// Position relative to the wrapper using the dot's SVG coords.
			const wrapRect = chartWrap.getBoundingClientRect();
			const left = (nearest.px / chartGeom.W) * wrapRect.width;
			const top = (nearest.py / chartGeom.H) * wrapRect.height;
			tooltipEl.style.left = `${left}px`;
			tooltipEl.style.top = `${Math.max(top - 6, 12)}px`;
		}
		function hideTooltip() { tooltipEl.classList.add('hidden'); }

		chartWrap.addEventListener('pointermove', (e) => showTooltipAt(e.clientX));
		chartWrap.addEventListener('pointerleave', hideTooltip);
		chartWrap.addEventListener('pointerdown', (e) => showTooltipAt(e.clientX));

		// ---- Controls --------------------------------------------------------
		root.querySelectorAll('[data-spacex-range]').forEach((btn) => {
			btn.addEventListener('click', () => {
				if (btn.disabled) return;
				range = btn.getAttribute('data-spacex-range');
				root.querySelectorAll('[data-spacex-range]').forEach((b) => {
					b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
				});
				// Fetch a longer history if this range needs more rows than we hold.
				ensureHistoryFor(range);
				renderChart();
			});
		});

		// ---- Data loading ----------------------------------------------------
		// Validate every third-party shape before trusting it. Require strict
		// numeric types and bound values to a plausible USD range so an absurd
		// figure can't become a non-finite/off-canvas coordinate.
		function parseQuote(j) {
			const d = j && j.data;
			if (!d || !inUsdRange(d.p)) return null;
			return {
				price: d.p,
				change: typeof d.c === 'number' ? d.c : null,
				changePct: typeof d.cp === 'number' ? d.cp : null,
				updatedAt: typeof d.u === 'string' ? d.u : null,
			};
		}
		function parseHistory(j) {
			const rows = j && Array.isArray(j.data) ? j.data : null;
			if (!rows) return [];
			const out = [];
			for (const row of rows) {
				if (!row) continue;
				// Use the close ('c'); require strict numeric type and a date string.
				if (typeof row.c !== 'number' || typeof row.t !== 'string') continue;
				const t = Date.parse(row.t);
				if (inUsdRange(row.c) && !isNaN(t)) out.push({ t, usd: row.c });
			}
			out.sort((a, b) => a.t - b.t);
			return out;
		}

		async function loadLatest() {
			// Serialise refreshes: drop an overlapping run so a slow earlier
			// response can't clobber fresher state.
			if (refreshing) return;
			refreshing = true;
			try {
				const j = await getJson(QUOTE_URL);
				if (disposed) return;
				const q = parseQuote(j);
				if (q) {
					spotUsd = q.price;
					dayChange = q.change;
					dayChangePct = q.changePct;
					spotUpdatedAt = q.updatedAt;
					renderLatest();
				} else if (latestEl.textContent === '—') {
					updatedEl.textContent = 'Couldn’t load the latest price right now — will retry shortly.';
				} else {
					// A refresh failed but we already have a price: keep it, note staleness.
					updatedEl.textContent = `${updatedEl.textContent.replace(/ · refresh failed$/, '')} · refresh failed`;
				}
			} catch {
				if (latestEl.textContent === '—') {
					updatedEl.textContent = 'Couldn’t load the latest price right now — will retry shortly.';
				} else {
					updatedEl.textContent = `${updatedEl.textContent.replace(/ · refresh failed$/, '')} · refresh failed`;
				}
			} finally {
				refreshing = false;
			}
		}

		// Fetch the history for the API range backing the requested UI range, if
		// we don't already hold it. Caches per API range so range toggles don't
		// refetch. Keeps the last good history on any failure.
		async function ensureHistoryFor(uiRange) {
			const apiRange = API_RANGE[uiRange] || '1Y';
			if (histCache[apiRange]) {
				if (histCache[apiRange].length >= history.length) history = histCache[apiRange];
				return;
			}
			try {
				const j = await getJson(histUrl(apiRange));
				if (disposed) return;
				const parsed = parseHistory(j);
				if (parsed.length) {
					histCache[apiRange] = parsed;
					// Prefer the longest series we hold so shorter windows can slice it.
					if (parsed.length >= history.length) history = parsed;
				}
			} catch {
				/* network/parse/timeout/abort — keep last good history, don't crash */
			}
			if (!disposed) renderChart();
		}

		async function init() {
			// Load latest and history in PARALLEL — a hung quote provider must not
			// block history (or vice versa). Each fetch is also timeout-bounded.
			await Promise.allSettled([loadLatest(), ensureHistoryFor(range)]);
			if (disposed) return;
			// Final re-render in case the chart was waiting on history.
			renderChart();
			if (disposed) return; // navigation may have fired during the awaits
			refreshTimer = setInterval(() => { if (!disposed) loadLatest(); }, REFRESH_MS);
		}

		// Teardown: stop the timer AND abort in-flight fetches AND flag disposed so
		// any awaiting init()/load resumes into a no-op (no render/timer against a
		// detached tree). Wired to both Astro's ClientRouter swap and page unload.
		function teardown() {
			if (disposed) return;
			disposed = true;
			if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }
			for (const ctrl of inflight) {
				try { ctrl.abort(); } catch { /* ignore */ }
			}
			inflight.clear();
		}
		document.addEventListener('astro:before-swap', teardown, { once: true });
		window.addEventListener('pagehide', teardown, { once: true });

		init();
	})();
</script>
