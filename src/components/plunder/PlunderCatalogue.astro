		svg: swatch('#386641',
			parrot('#6a994e') +
			`<g transform="translate(60 72)"><path d="M-18 -6 q18 -10 36 0 l4 28 l-44 0 z" fill="#ffd166"/>` +
			`<path d="M-18 -6 q18 12 36 0" fill="none" stroke="#e6a700" stroke-width="2"/></g>`),
	},
