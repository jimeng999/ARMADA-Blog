			`<path d="M60 44 q-6 -34 6 -36 q6 14 0 34 z" fill="#e63946"/>` +
			`<path d="M60 44 q10 -30 22 -28 q-2 16 -16 30 z" fill="#f4a261"/>`),
	},
	{
		id: 'rainbow-ruff',
		name: 'Rainbow Wing Ruff',
		category: 'finery',
		price: '14 doubloons',
		desc: 'A collar of cascading feathers — strut the deck like a true lory.',
		svg: swatch('#3d348b',
			`<g transform="translate(60 60)">` +
			`<path d="M0 0 l-30 24 l8 -30 z" fill="#e63946"/>` +
			`<path d="M0 0 l-14 34 l18 -22 z" fill="#f4a261"/>` +
			`<path d="M0 0 l10 34 l8 -30 z" fill="#ffd166"/>` +
			`<path d="M0 0 l30 22 l-2 -30 z" fill="#2a9d8f"/></g>`),
	},
	{
		id: 'beak-bling',
		name: 'Gilded Beak Bling',
		category: 'finery',
		price: '9 doubloons',
		desc: 'A wee gold beak-band for the parrot who already has everything.',
		svg: swatch('#264653',
			parrot('#2a9d8f') +
			`<rect x="64" y="36" width="14" height="5" rx="2.5" fill="#ffd166"/>`),
	},
	// --- Perch Wear ---
	{
		id: 'striped-jumper',
		name: 'Salty Stripes Jumper',
		category: 'perch',
		price: '12 doubloons',
		desc: 'A breton-striped knit so your parrot blends in with the crew.',
		svg: swatch('#1d3557',
			parrot('#457b9d') +
			`<g transform="translate(60 70)"><rect x="-18" y="-4" width="36" height="26" rx="10" fill="#f1faee"/>` +
			`<rect x="-18" y="2" width="36" height="3" fill="#1d3557"/>` +
			`<rect x="-18" y="10" width="36" height="3" fill="#1d3557"/></g>`),
