---
// Polly's Plunder — a BROWSE-ONLY catalogue of parrot apparel & accessories.
//
// CRITICAL: This is purely for fun. There is NO real checkout, NO payment
// provider, NO money handling, NO backend and NO external network calls.
// Every product, price and illustration is STATIC data defined right here in
// the repo; illustrations are inline SVG (no hotlinked images). The optional
// "booty" cart is a cosmetic counter persisted to localStorage — no doubloons
// ever change hands.
//
// Matches the games / shipyard island pattern: scoped markup, theme-aware
// colours via CSS variables, and a single inline IIFE that re-binds itself on
// Astro client-router swaps. All dynamic text is written via textContent
// (never innerHTML) to avoid injection.

const categories = [
	{ id: 'all', label: 'All Plunder' },
	{ id: 'finery', label: 'Feathered Finery' },
	{ id: 'perch', label: 'Perch Wear' },
	{ id: 'trinkets', label: 'Trinkets & Booty' },
	{ id: 'bundles', label: 'Crew Bundles' },
];

// SVG illustration builders — each draws a self-contained little scene.
const swatch = (bg: string, inner: string) =>
	`<svg viewBox="0 0 120 120" width="100%" height="100%" role="img" preserveAspectRatio="xMidYMid meet" aria-hidden="true">` +
	`<rect width="120" height="120" rx="14" fill="${bg}"/>${inner}</svg>`;

const parrot = (body: string, belly = '#ffd166') =>
	`<g transform="translate(60 64)">` +
	`<ellipse cx="0" cy="6" rx="26" ry="32" fill="${body}"/>` +
	`<ellipse cx="0" cy="14" rx="15" ry="20" fill="${belly}"/>` +
	`<circle cx="0" cy="-26" r="16" fill="${body}"/>` +
	`<circle cx="-5" cy="-28" r="3.2" fill="#1b1b1b"/>` +
	`<path d="M8 -26 q16 0 14 12 q-10 -2 -14 -2 z" fill="#f4a261"/>` +
	`<path d="M-24 -2 q-22 6 -16 30 q14 -8 18 -22 z" fill="${body}" opacity="0.85"/>` +
	`</g>`;

const products = [
