---
// OceanHero — a fixed-position, parallax WebGL backdrop: a stylised sailing ship
// riding a procedural FBM ocean under a soft maritime sky. Rendered behind the
// scrolling page content so the page rolls over it (rolling-window depth).
//
// Original work — the ocean (FBM/value-noise waves), sky gradient, sun glint and
// the ship are all hand-written here. Inspired by dr2's "Sailing" on Shadertoy,
// but no CC-licensed code is copied or vendored; this stays under the repo license.
//
// Theme-aware: the shader reads the active colour theme (the same system
// ThemeToggle drives — the `.dark` class and `data-theme` attribute on <html>).
// In the "Tempest watch" (storm) theme the sea turns genuinely stormy — bigger,
// choppier waves, a dark desaturated palette, overcast light (no sun-glint),
// whitecap foam and an occasional lightning flash. The transition is animated via
// a uStorm uniform that eases toward the target, and it updates LIVE when the
// theme changes via the picker (a MutationObserver on <html>, plus astro:after-swap)
// with no reload. Other themes keep the calm sea.
//
// Fallbacks & guards (see the inline script):
//   - prefers-reduced-motion  -> no animation; renders a single still frame; in
//                                 storm theme the still frame is stormy but the
//                                 lightning flash is suppressed (no strobing)
//   - WebGL unavailable        -> canvas hidden, CSS gradient fallback shown
//   - perf guard               -> DPR capped; pauses when offscreen; downgrades
//                                 resolution / pauses if FPS drops below ~30
---

<div id="ocean-hero" aria-hidden="true" class="ocean-hero pointer-events-none">
	{/* Static CSS fallback: a maritime gradient that is always painted first, so
	    there is never a black/broken canvas even before (or without) WebGL. */}
	<div class="ocean-hero__fallback"></div>
	<canvas id="ocean-hero-canvas" class="ocean-hero__canvas"></canvas>
</div>

<style>
	.ocean-hero {
		position: fixed;
		inset: 0;
		z-index: -1; /* sit behind all page content */
		overflow: hidden;
	}
	.ocean-hero__fallback {
		position: absolute;
		inset: 0;
		/* Sky-to-sea wash in the maritime palette; visible if WebGL is absent. */
		background:
			radial-gradient(120% 80% at 50% 8%, oklch(0.86 0.06 230 / 0.9), transparent 60%),
			linear-gradient(
				to bottom,
				oklch(0.9 0.04 235) 0%,
				oklch(0.82 0.06 225) 42%,
				oklch(0.6 0.09 220) 56%,
				oklch(0.42 0.08 220) 100%
			);
		opacity: 0.55;
	}
	:global(.dark) .ocean-hero__fallback {
		background:
			radial-gradient(120% 80% at 50% 8%, oklch(0.4 0.06 250 / 0.9), transparent 60%),
			linear-gradient(
				to bottom,
				oklch(0.32 0.05 255) 0%,
				oklch(0.26 0.05 250) 45%,
				oklch(0.2 0.05 245) 58%,
				oklch(0.14 0.04 245) 100%
			);
		opacity: 0.7;
	}
	/* Tropical theme ("sun-bleached lagoon"): a bright turquoise-to-sand wash
	   for the no-WebGL fallback. Tropical is a light-derived preset, so without
	   this rule it fell through to the default (cool-blue) light fallback above —
	   the wrong palette, which read as out of alignment against the warm lagoon
	   theme. This mirrors the LIGHT fallback's geometry exactly (same radial
	   position 50% 8% / transparent 60%, same 4-stop vertical wash, same
	   opacity: 0.55) so positioning/sizing is identical to the other themes — only
	   the palette is swapped to the lagoon's turquoise/sand. */
	:global([data-theme='tropical']) .ocean-hero__fallback {
		background:
			radial-gradient(120% 80% at 50% 8%, oklch(0.92 0.05 200 / 0.9), transparent 60%),
			linear-gradient(
				to bottom,
				oklch(0.95 0.045 110) 0%,
				oklch(0.88 0.07 195) 42%,
				oklch(0.68 0.10 200) 56%,
				oklch(0.5 0.105 205) 100%
			);
		opacity: 0.55;
	}
	/* Storm theme: a darker, desaturated overcast wash for the no-WebGL fallback,
	   so the CSS-only path also reads stormy when "Tempest watch" is active. */
	:global([data-theme='storm']) .ocean-hero__fallback {
		background:
			radial-gradient(120% 80% at 50% 6%, oklch(0.34 0.02 250 / 0.9), transparent 58%),
			linear-gradient(
				to bottom,
				oklch(0.30 0.02 250) 0%,
				oklch(0.24 0.022 250) 44%,
				oklch(0.18 0.02 248) 58%,
				oklch(0.12 0.018 248) 100%
			);
		opacity: 0.78;
	}
	.ocean-hero__canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
		opacity: 0;
		transition: opacity 600ms ease;
	}
	/* Revealed by the script once the first frame has drawn, so we never flash a
	   black canvas before the GL context paints. */
	.ocean-hero.is-ready .ocean-hero__canvas {
		opacity: 0.55;
	}
	:global(.dark) .ocean-hero.is-ready .ocean-hero__canvas {
		opacity: 0.7;
	}
</style>

<script is:inline>
	// OceanHero lifecycle. Astro's ClientRouter swaps the DOM on SPA navigation
	// without a full reload, so a hero that only inits on first load would (a)
	// leak its WebGL context every time you leave the page — quickly hitting the
	// browser's ~16-context limit — and (b) fail to re-init when you return.
	//
	// So we expose init/teardown and drive them off the router lifecycle:
	//   - astro:page-load   -> (re)initialise (also fires on the initial load)
	//   - astro:before-swap -> tear down: cancel RAF, drop listeners/observers,
	//                          and release the GL context via loseContext()
	// The live instance's teardown is parked on window.__oceanHeroTeardown so a
	// stray double page-load can't spin up two contexts (guard against double-init).
	(() => {
		function initOceanHero() {
			const root = document.getElementById('ocean-hero');
			const canvas = document.getElementById('ocean-hero-canvas');
			if (!root || !canvas) return;

			// Guard against double-init: if an instance is already live (e.g. a
			// duplicate page-load), tear it down before starting a fresh one.
			if (window.__oceanHeroTeardown) {
				try { window.__oceanHeroTeardown(); } catch (_) {}
				window.__oceanHeroTeardown = null;
			}

			const reduceMotion =
				window.matchMedia &&
				window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			// --- Acquire a WebGL context; bail to the CSS fallback if unavailable. ---
			let gl = null;
			try {
				gl =
					canvas.getContext('webgl', { antialias: false, alpha: true, premultipliedAlpha: false }) ||
					canvas.getContext('experimental-webgl', { antialias: false, alpha: true });
			} catch (_) {
				gl = null;
			}
			if (!gl) {
				// Leave the canvas hidden; the CSS gradient fallback remains visible.
				return;
			}

			// Release the WebGL context and reset the canvas. Used by every exit
			// path below so a torn-down hero never leaves a context dangling.
			function releaseGL() {
				try {
					const lose = gl.getExtension('WEBGL_lose_context');
					if (lose) lose.loseContext();
				} catch (_) {}
				gl = null;
			}

		// --- Shaders -----------------------------------------------------------
		const vertSrc = `
			attribute vec2 aPos;
			void main() { gl_Position = vec4(aPos, 0.0, 1.0); }
		`;

		// Original procedural sea + stylised ship. FBM value-noise drives the
		// swell; a simple SDF-ish hull + two sails sit on the horizon.
		const fragSrc = `
			precision mediump float;
			uniform vec2  uRes;
			uniform float uTime;
			// Storm intensity 0..1, eased toward the active theme on the JS side:
			// 0 = calm sea (light/dark/tropical), 1 = full "Tempest watch" storm.
			uniform float uStorm;
			// 1.0 when prefers-reduced-motion is on — suppresses the lightning
			// strobe so the storm still reads stormy without flashing.
			uniform float uReduce;

			// --- hash / value noise / fbm (original, classic ingredients) ------
			float hash(vec2 p) {
				p = fract(p * vec2(123.34, 456.21));
				p += dot(p, p + 45.32);
				return fract(p.x * p.y);
			}
			float noise(vec2 p) {
				vec2 i = floor(p);
				vec2 f = fract(p);
				vec2 u = f * f * (3.0 - 2.0 * f);
				float a = hash(i);
				float b = hash(i + vec2(1.0, 0.0));
				float c = hash(i + vec2(0.0, 1.0));
				float d = hash(i + vec2(1.0, 1.0));
				return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
			}
			// gain shapes the per-octave amplitude falloff: a higher gain keeps more
			// energy in the finer octaves, giving steeper, choppier swell. We raise
			// gain with the storm so the seas get rougher, not just taller.
			float fbm(vec2 p, float gain) {
				float v = 0.0;
				float amp = 0.5;
				mat2 rot = mat2(0.8, 0.6, -0.6, 0.8);
				for (int i = 0; i < 5; i++) {
					v += amp * noise(p);
					p = rot * p * 2.02;
					amp *= gain;
				}
				return v;
			}

			void main() {
				vec2 uv = gl_FragCoord.xy / uRes.xy;     // 0..1, y up
				float aspect = uRes.x / uRes.y;
				float horizon = 0.56;                    // sea/sky split

				// ---- Sky -------------------------------------------------------
				// Calm sky; in the storm it desaturates to a dim overcast slate.
				vec3 skyTop = vec3(0.43, 0.62, 0.80);
				vec3 skyLow = vec3(0.78, 0.84, 0.86);
				vec3 stormTop = vec3(0.07, 0.08, 0.11);
				vec3 stormLow = vec3(0.15, 0.17, 0.21);
				skyTop = mix(skyTop, stormTop, uStorm);
				skyLow = mix(skyLow, stormLow, uStorm);
				vec3 sky = mix(skyLow, skyTop, smoothstep(horizon, 1.0, uv.y));
				// Sun glow upper-centre-right — faded out under storm cloud cover.
				vec2 sun = vec2(0.62, 0.86);
				float sunD = distance(vec2(uv.x * aspect, uv.y), vec2(sun.x * aspect, sun.y));
				sky += vec3(1.0, 0.93, 0.78) * smoothstep(0.5, 0.0, sunD) * 0.5 * (1.0 - uStorm);
				// Roiling storm clouds: a slow dark FBM layer rolling across the sky.
				if (uStorm > 0.001) {
					float cloud = fbm(vec2(uv.x * aspect * 2.2, uv.y * 2.6) + vec2(uTime * 0.04, 0.0), 0.55);
					cloud = smoothstep(0.25, 0.8, cloud);
					sky = mix(sky, sky * vec3(0.42, 0.45, 0.52), cloud * uStorm * 0.85);
					// Pull the whole sky down a touch so it never reads sunny.
					sky *= mix(1.0, 0.8, uStorm);
				}

				// ---- Sea -------------------------------------------------------
				// Project screen space into a faux-perspective sea plane: rows
				// near the horizon compress, foreground stretches.
				float depth = (horizon - uv.y) / horizon;        // 0 at horizon..1 near
				depth = clamp(depth, 0.0, 1.0);
				float persp = 1.0 / (depth + 0.06);
				vec2 sea;
				sea.x = (uv.x - 0.5) * aspect * persp * 1.4;
				sea.y = persp * 1.2 + uTime * 0.18;

				// Storm pushes the FBM gain up (steeper, choppier octaves) and speeds
				// the swell so the surface churns rather than gently rolling.
				float gain = mix(0.5, 0.72, uStorm);
				float spd  = mix(1.0, 1.7, uStorm);
				float swell = fbm(sea * 2.0 + vec2(0.0, uTime * 0.05 * spd), gain);
				swell += 0.5 * fbm(sea * 5.0 - vec2(uTime * 0.07 * spd, 0.0), gain);
				// A third, finer octave only in the storm — the white-cap chop.
				swell += uStorm * 0.35 * fbm(sea * 9.0 + vec2(uTime * 0.12, uTime * 0.04), gain);
				// Larger amplitude (taller waves) as the storm builds.
				swell *= mix(1.0, 1.45, uStorm);
				swell *= mix(0.25, 1.0, depth);                  // calmer toward horizon

				// Palette: calm teal sea darkens to a desaturated steel-slate in the storm.
				vec3 seaDeep = mix(vec3(0.06, 0.20, 0.32), vec3(0.04, 0.07, 0.11), uStorm);
				vec3 seaLite = mix(vec3(0.30, 0.55, 0.62), vec3(0.20, 0.26, 0.31), uStorm);
				vec3 water = mix(seaDeep, seaLite, swell);

				// Sun glint streak on the water — overcast storm kills it.
				float glint = smoothstep(0.45, 0.0, abs(uv.x - 0.6)) *
				              smoothstep(0.0, 0.18, depth) *
				              (0.5 + 0.5 * sin(swell * 24.0 + uTime));
				water += vec3(1.0, 0.95, 0.8) * glint * 0.18 * (1.0 - uStorm);

				// Crest highlights (calm sea sparkle).
				water += vec3(0.9) * smoothstep(0.7, 0.95, swell) * 0.25 * (1.0 - 0.4 * uStorm);

				// Whitecaps / foam: in the storm the steepest crests blow out to cold
				// grey-white foam, broken up by noise so it reads as spray, not a band.
				if (uStorm > 0.001) {
					float foamN = noise(sea * 14.0 + vec2(uTime * 0.6, uTime * 0.2));
					float foam = smoothstep(0.62, 0.86, swell) * foamN;
					foam *= mix(0.2, 1.0, depth);
					water = mix(water, vec3(0.78, 0.82, 0.86), clamp(foam, 0.0, 1.0) * uStorm * 0.9);
				}

				vec3 col = uv.y > horizon ? sky : water;

				// ---- Ship (stylised silhouette on the horizon) -----------------
				// Centre it slightly left, bobbing gently with the swell.
				float bob = sin(uTime * 0.8) * 0.006;
				vec2 sp = vec2((uv.x - 0.40) * aspect, uv.y - (horizon + 0.012 + bob));
				float ship = 0.0;

				// Hull: a shallow arc (wider at the waterline, tapering up).
				float hullW = 0.085;
				float hullH = 0.028;
				float hullArc = sp.y + 0.5 * (sp.x / hullW) * (sp.x / hullW) * hullH;
				if (abs(sp.x) < hullW && hullArc > -hullH && hullArc < 0.0) ship = 1.0;

				// Two masts.
				if (abs(sp.x + 0.018) < 0.0035 && sp.y > 0.0 && sp.y < 0.16) ship = 1.0;
				if (abs(sp.x - 0.030) < 0.0035 && sp.y > 0.0 && sp.y < 0.13) ship = 1.0;

				// Sails: triangles billowing off each mast.
				float s1 = step(0.0, sp.y) * step(sp.y, 0.15) *
				           step(-0.02, sp.x + 0.014) *
				           step(sp.x + 0.014, 0.05 * (1.0 - sp.y / 0.15));
				float s2 = step(0.0, sp.y) * step(sp.y, 0.12) *
				           step(-0.018, sp.x - 0.034) *
				           step(sp.x - 0.034, 0.045 * (1.0 - sp.y / 0.12));
				float sails = max(s1, s2);

				vec3 hullCol = vec3(0.13, 0.09, 0.07);
				vec3 sailCol = vec3(0.96, 0.93, 0.84);
				col = mix(col, hullCol, ship);
				col = mix(col, sailCol, sails * 0.92);

				// Subtle wake glow beneath the hull.
				float wake = smoothstep(0.05, 0.0, length(vec2(sp.x, (sp.y + 0.02) * 2.5))) *
				             step(sp.y, -0.005);
				col += vec3(0.8, 0.9, 1.0) * wake * 0.12;

				// ---- Lightning ------------------------------------------------
				// An occasional flash: a hash keyed to the current ~2.3s window fires
				// only when it clears a high threshold, so strikes are sparse and
				// irregular. Gated by uStorm and fully OFF under reduced motion
				// (uReduce) so there is no strobing for motion-sensitive users.
				float flashGate = uStorm * (1.0 - uReduce);
				if (flashGate > 0.001) {
					float seg = floor(uTime / 2.3);
					float strike = hash(vec2(seg, 7.0));
					// Only the top slice of segments fire; each is a fast decaying pulse.
					float fire = step(0.78, strike);
					float local = fract(uTime / 2.3);
					float pulse = fire * exp(-local * 18.0) * (0.6 + 0.4 * hash(vec2(seg, 3.0)));
					// Brighten the sky more than the sea, biased to the upper half.
					float skyBias = smoothstep(horizon - 0.1, 1.0, uv.y);
					col += vec3(0.7, 0.78, 0.95) * pulse * flashGate * mix(0.25, 1.0, skyBias);
				}

				// Vignette for focus — tightened in the storm for a moodier frame.
				float vig = smoothstep(1.25, 0.35, distance(uv, vec2(0.5)));
				col *= mix(0.82, 1.0, vig);
				col *= mix(1.0, 0.9, uStorm);

				gl_FragColor = vec4(col, 1.0);
			}
		`;

		function compile(type, src) {
			const sh = gl.createShader(type);
			gl.shaderSource(sh, src);
			gl.compileShader(sh);
			if (!gl.getShaderParameter(sh, gl.COMPILE_STATUS)) {
				gl.deleteShader(sh);
				return null;
			}
			return sh;
		}

		const vs = compile(gl.VERTEX_SHADER, vertSrc);
		const fs = compile(gl.FRAGMENT_SHADER, fragSrc);
		if (!vs || !fs) { releaseGL(); return; } // compile failure -> CSS fallback stays

		const prog = gl.createProgram();
		gl.attachShader(prog, vs);
		gl.attachShader(prog, fs);
		gl.linkProgram(prog);
		if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) { releaseGL(); return; }
		gl.useProgram(prog);

		// Fullscreen triangle.
		const buf = gl.createBuffer();
		gl.bindBuffer(gl.ARRAY_BUFFER, buf);
		gl.bufferData(
			gl.ARRAY_BUFFER,
			new Float32Array([-1, -1, 3, -1, -1, 3]),
			gl.STATIC_DRAW
		);
		const aPos = gl.getAttribLocation(prog, 'aPos');
		gl.enableVertexAttribArray(aPos);
		gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

		const uRes = gl.getUniformLocation(prog, 'uRes');
		const uTime = gl.getUniformLocation(prog, 'uTime');
		const uStorm = gl.getUniformLocation(prog, 'uStorm');
		const uReduce = gl.getUniformLocation(prog, 'uReduce');

		// --- Theme awareness -----------------------------------------------
		// The active theme is the same signal ThemeToggle drives: the storm
		// preset sets data-theme="storm" (and .dark) on <html>. We read that
		// straight off the document so we never duplicate the theme registry,
		// then ease a uStorm uniform toward 1 (storm) or 0 (calm) so switching
		// themes via the picker visibly rolls the sea up/down with no reload.
		function targetStorm() {
			try {
				return document.documentElement.getAttribute('data-theme') === 'storm' ? 1.0 : 0.0;
			} catch (_) { return 0.0; }
		}
		// Reduced-motion is a fixed flag for the lifetime of this instance.
		gl.uniform1f(uReduce, reduceMotion ? 1.0 : 0.0);
		// Seed the eased value at the target so the first paint is already correct.
		let stormTarget = targetStorm();
		let stormValue = stormTarget;

		// --- Perf guard state --------------------------------------------------
		// Cap devicePixelRatio so high-DPI screens don't shade 4x the pixels.
		let dprCap = 1.5;
		let quality = 1.0; // resolution scale; downgraded if FPS sags

		function resize() {
			const w = root.clientWidth || window.innerWidth;
			const h = root.clientHeight || window.innerHeight;
			const dpr = Math.min(window.devicePixelRatio || 1, dprCap) * quality;
			const cw = Math.max(1, Math.floor(w * dpr));
			const ch = Math.max(1, Math.floor(h * dpr));
			if (canvas.width !== cw || canvas.height !== ch) {
				canvas.width = cw;
				canvas.height = ch;
			}
			gl.viewport(0, 0, canvas.width, canvas.height);
			gl.uniform2f(uRes, canvas.width, canvas.height);
		}

		let ready = false;
		function drawFrame(tSeconds) {
			resize();
			// Ease the storm uniform toward its target so a theme switch ramps
			// the sea up/down (~0.6s) instead of snapping. dt is unknown here, so
			// use a fixed per-frame step — good enough for a cosmetic transition.
			stormValue += (stormTarget - stormValue) * 0.08;
			if (Math.abs(stormTarget - stormValue) < 0.002) stormValue = stormTarget;
			gl.uniform1f(uStorm, stormValue);
			gl.uniform1f(uTime, tSeconds);
			gl.drawArrays(gl.TRIANGLES, 0, 3);
			if (!ready) {
				ready = true;
				root.classList.add('is-ready');
			}
		}

		// --- Reduced motion: a single still frame, no RAF loop. ----------------
		// The frame still reflects the theme (a stormy still for storm), but the
		// shader suppresses the lightning strobe via uReduce. A theme switch while
		// reduced-motion is on snaps the uniform and redraws the single frame.
		if (reduceMotion) {
			const drawStill = () => { stormValue = targetStorm(); stormTarget = stormValue; drawFrame(8.0); };
			drawStill();
			const onResizeStill = () => drawStill();
			window.addEventListener('resize', onResizeStill, { passive: true });
			// Observe theme changes on <html> so the still frame updates live when
			// the picker switches themes (no reload), then redraw the still.
			const themeObsStill = new MutationObserver(drawStill);
			themeObsStill.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'data-theme'] });
			document.addEventListener('astro:after-swap', drawStill);
			// Teardown for the still path: drop the listeners/observer and release
			// GL so nothing is leaked across SPA navigation.
			window.__oceanHeroTeardown = () => {
				window.removeEventListener('resize', onResizeStill);
				themeObsStill.disconnect();
				document.removeEventListener('astro:after-swap', drawStill);
				releaseGL();
				window.__oceanHeroTeardown = null;
			};
			return;
		}

		// --- Animated path with FPS / visibility guards ------------------------
		let running = true;     // hero on-screen
		let rafId = 0;
		let startTs = 0;
		let lastTs = 0;
		let frames = 0;
		let fpsAccum = 0;
		let downgraded = false;

		function loop(ts) {
			if (!running) return;
			if (!startTs) startTs = ts;
			const elapsed = (ts - startTs) / 1000;

			drawFrame(elapsed);

			// FPS sampling over ~1s windows.
			if (lastTs) {
				const dt = ts - lastTs;
				fpsAccum += dt;
				frames++;
				if (fpsAccum >= 1000) {
					const fps = (frames * 1000) / fpsAccum;
					if (fps < 30) {
						if (!downgraded) {
							// First strike: drop resolution to lighten the load.
							downgraded = true;
							quality = 0.6;
							dprCap = 1.0;
						} else {
							// Still struggling: stop animating, keep last frame.
							running = false;
							cancelAnimationFrame(rafId);
							return;
						}
					}
					frames = 0;
					fpsAccum = 0;
				}
			}
			lastTs = ts;
			rafId = requestAnimationFrame(loop);
		}

		function startLoop() {
			if (running && !rafId) {
				lastTs = 0;
				startTs = 0;
				rafId = requestAnimationFrame(loop);
			}
		}
		function stopLoop() {
			cancelAnimationFrame(rafId);
			rafId = 0;
		}

		// Pause when the hero scrolls fully out of view (saves battery/CPU).
		let io = null;
		if ('IntersectionObserver' in window) {
			io = new IntersectionObserver(
				(entries) => {
					const visible = entries[0] && entries[0].isIntersecting;
					if (visible && running) startLoop();
					else stopLoop();
				},
				{ threshold: 0 }
			);
			io.observe(root);
		}

		// Pause on tab hide.
		const onVisibility = () => {
			if (document.hidden) stopLoop();
			else if (running) startLoop();
		};
		document.addEventListener('visibilitychange', onVisibility);

		window.addEventListener('resize', resize, { passive: true });

		// Theme awareness, live: watch <html> for class / data-theme changes so
		// flipping to (or from) the storm theme via the picker rolls the sea up
		// or down with no reload. astro:after-swap re-reads it too, since the
		// no-flash script re-applies the theme onto the swapped-in <html>. Both
		// just retarget the eased uStorm value the loop animates toward.
		const syncStorm = () => { stormTarget = targetStorm(); if (running) startLoop(); };
		const themeObs = new MutationObserver(syncStorm);
		themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'data-theme'] });
		document.addEventListener('astro:after-swap', syncStorm);
		// Teardown for the animated path: stop the RAF loop, drop every listener
		// and the observer, then release the GL context. Parked on window so the
		// router lifecycle (and any double page-load) can reclaim it.
		window.__oceanHeroTeardown = () => {
			running = false;
			stopLoop();
			if (io) { io.disconnect(); io = null; }
			themeObs.disconnect();
			document.removeEventListener('astro:after-swap', syncStorm);
			document.removeEventListener('visibilitychange', onVisibility);
			window.removeEventListener('resize', resize);
			releaseGL();
			window.__oceanHeroTeardown = null;
		};

		// Kick off.
		running = true;
		rafId = requestAnimationFrame(loop);
		}

		// --- Router lifecycle wiring (bound once) ------------------------------
		// astro:page-load fires on the initial load AND after every ClientRouter
		// swap, so it's the single entry point for (re)initialisation. We bind the
		// lifecycle listeners once (guarded) and let initOceanHero handle re-runs.
		if (!window.__oceanHeroLifecycleBound) {
			window.__oceanHeroLifecycleBound = true;
			document.addEventListener('astro:page-load', initOceanHero);
			document.addEventListener('astro:before-swap', () => {
				if (window.__oceanHeroTeardown) {
					try { window.__oceanHeroTeardown(); } catch (_) {}
					window.__oceanHeroTeardown = null;
				}
			});
		}
	})();
</script>
