{
  "triggerLabel": "armada",
  "dispatch": "shipwright",
  "baseBranch": "main",
  "authors": "",
  "autoMerge": true,
  "mergeMethod": "squash",
  "maxReviewRounds": 2,
  "maxConcurrentBuilds": 3,
  "maxConcurrentReviews": 3,
  "armadaRepo": "calumjs/ARMADA",
